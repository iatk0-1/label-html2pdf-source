<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.label.LoginController"
      spacing="12" alignment="CENTER" styleClass="login-pane">

    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

    <Label text="打单软件登录" styleClass="login-title"/>

    <!-- Server settings row: hidden by default, toggle with settings button -->
    <HBox fx:id="serverRow" spacing="8" alignment="CENTER_LEFT" visible="false" managed="false">
        <Label text="服务器:" prefWidth="60"/>
        <TextField fx:id="serverField" HBox.hgrow="ALWAYS" promptText="http://192.168.10.217:8080"/>
    </HBox>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="用户名:" prefWidth="60"/>
        <TextField fx:id="usernameField" HBox.hgrow="ALWAYS" promptText="打印机账号"/>
    </HBox>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="密码:" prefWidth="60"/>
        <PasswordField fx:id="passwordField" HBox.hgrow="ALWAYS" promptText="密码"/>
    </HBox>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <CheckBox fx:id="rememberPwdCheck" text="记住密码"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="settingsBtn" text="设置" onAction="#onSettings"/>
    </HBox>

    <Label fx:id="statusLabel" styleClass="login-status"/>

    <HBox spacing="12" alignment="CENTER">
        <Button fx:id="loginBtn" text="登录" defaultButton="true" onAction="#onLogin" styleClass="btn-primary"/>
        <Button text="取消" onAction="#onCancel"/>
    </HBox>

</VBox>